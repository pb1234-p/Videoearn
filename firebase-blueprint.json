{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user balance and payment details",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "balance": { "type": "number", "description": "Current balance in INR" },
        "totalEarned": { "type": "number", "description": "Total amount earned to date" },
        "upiId": { "type": "string", "description": "Default UPI ID for withdrawals" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "balance", "totalEarned"]
    },
    "Video": {
      "title": "Video Task",
      "description": "Admin-defined video task for users to earn money",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "youtubeUrl": { "type": "string", "format": "uri" },
        "rewardAmount": { "type": "number", "description": "Reward in INR" },
        "duration": { "type": "number", "description": "Required watch time in seconds" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "youtubeUrl", "rewardAmount", "duration"]
    },
    "WatchedVideo": {
      "title": "Watched Video Record",
      "description": "Prevents users from earning multiple times from the same video",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "videoId": { "type": "string" },
        "watchedAt": { "type": "string", "format": "date-time" },
        "rewardEarned": { "type": "number" }
      },
      "required": ["userId", "videoId", "watchedAt", "rewardEarned"]
    },
    "WithdrawalRequest": {
      "title": "Withdrawal Request",
      "description": "Request from a user to withdraw their balance",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "upiId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "amount", "upiId", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "Available video tasks"
    },
    "/watched_videos/{recordId}": {
      "schema": "WatchedVideo",
      "description": "Records of completed video tasks"
    },
    "/withdrawals/{requestId}": {
      "schema": "WithdrawalRequest",
      "description": "User withdrawal requests"
    }
  }
}
